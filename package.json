    "@fontsource/lora": "^5.0.16",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.8",
    "@typescript-eslint/eslint-plugin": "^7.3.1",
    "@typescript-eslint/parser": "^7.3.1",
    "astro": "^6.1.9",
    "clsx": "^2.1.0",
    "eslint": "^8.57.0",
    "eslint-plugin-astro": "^0.32.0",
    "eslint-plugin-jsx-a11y": "^6.8.0",
    "sharp": "^0.33.3",
